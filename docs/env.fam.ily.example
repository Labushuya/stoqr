# ── stoqr — Production Environment ───────────────────────────────────────────
# Pfad: /srv/hubdata/stacks/stoqr/.env
# Dieses File NIEMALS committen oder in Backups ohne Verschlüsselung ablegen.

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=stoqr.fam.ily

# ── Datenbank ─────────────────────────────────────────────────────────────────
# Generieren: openssl rand -base64 24 | tr -d '=+/'
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── Auth (Better Auth) ────────────────────────────────────────────────────────
# Generieren: openssl rand -base64 32
# WICHTIG: Muss exakt mit der öffentlichen URL übereinstimmen (kein Trailing-Slash)
BETTER_AUTH_SECRET=CHANGE_ME_BETTER_AUTH_SECRET
BETTER_AUTH_URL=https://stoqr.fam.ily
PUBLIC_APP_URL=https://stoqr.fam.ily

# ── Verschlüsselung (Bring!-Credentials in DB) ────────────────────────────────
# Generieren: openssl rand -hex 32  (ergibt 64 Hex-Zeichen)
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ── Zeitzone ──────────────────────────────────────────────────────────────────
TZ=Europe/Berlin

# ── Open Food Facts ───────────────────────────────────────────────────────────
# Optionaler User-Agent für OFF-API-Anfragen
OFF_USER_AGENT=stoqr/0.1.0 (https://github.com/Labushuya/stoqr)
