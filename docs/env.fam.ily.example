# stoqr — Secret-Datei
# Pfad auf dem Pi: /srv/hubdata/state/stoqr/.env
# Berechtigungen:  chmod 600 /srv/hubdata/state/stoqr/.env
#
# NIEMALS committen. NIEMALS in Backups ohne Verschlüsselung ablegen.
# Alle CHANGE_ME-Werte auf dem Pi generieren (siehe deployment-fam-ily.md).

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Wird von beiden Services (stoqr + postgres) gelesen.
POSTGRES_DB=stoqr
POSTGRES_USER=stoqr
# Generieren: openssl rand -base64 24 | tr -d '=+/'
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── App: Datenbankverbindung ──────────────────────────────────────────────────
# Muss POSTGRES_USER, POSTGRES_PASSWORD und POSTGRES_DB spiegeln.
DATABASE_URL=postgresql://stoqr:CHANGE_ME_DB_PASSWORD@postgres:5432/stoqr

# ── Auth (Better Auth) ────────────────────────────────────────────────────────
# Generieren: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_BETTER_AUTH_SECRET
BETTER_AUTH_URL=https://stoqr.fam.ily
PUBLIC_APP_URL=https://stoqr.fam.ily

# ── Verschlüsselung (Bring!-Credentials in DB) ────────────────────────────────
# Generieren: openssl rand -hex 32  (= 64 Hex-Zeichen)
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ── App-Einstellungen ─────────────────────────────────────────────────────────
TZ=Europe/Berlin
NODE_ENV=production
OFF_USER_AGENT=stoqr/0.1.0 (https://github.com/Labushuya/stoqr)
