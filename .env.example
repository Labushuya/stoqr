# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://stoqr:CHANGE_ME@postgres:5432/stoqr

# ── Auth (Better Auth) ────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING
BETTER_AUTH_URL=http://localhost:5173

# ── App ───────────────────────────────────────────────────
PUBLIC_APP_URL=http://localhost:5173
TZ=Europe/Berlin
NODE_ENV=development

# ── Bring! Integration ────────────────────────────────────
# Your Bring! account credentials (stored encrypted in DB)
# Configure via the Settings UI after first login
# BRING_EMAIL=your@email.com
# BRING_PASSWORD=your_bring_password

# ── Open Food Facts ───────────────────────────────────────
OFF_USER_AGENT=stoqr/0.1.0 (https://github.com/Labushuya/stoqr)

# ── Online-Preis-Abruf (Block F2/G4) ──────────────────────
# Der Ein/Aus-Schalter liegt jetzt IN DER APP (Einstellungen → Online-Preis-Abruf),
# household-weit in der DB — keine Env-Variable mehr nötig. Optional nur der
# User-Agent fuer die Scrape-Requests:
# PRICE_SCRAPE_USER_AGENT=stoqr-price/0.1

# ── Encryption (for Bring! credentials in DB) ────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
